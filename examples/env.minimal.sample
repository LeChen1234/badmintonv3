# 最小可用配置示例（复制为项目根目录 .env 后使用）
# 本机运行请使用 localhost 作为各服务主机名

# 数据库（必填）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=badminton
POSTGRES_PASSWORD=badminton_secret_2024
POSTGRES_DB=badminton_annotation

# Redis（必填）
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO（导出/存储帧时可填）
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_BUCKET=badminton-frames
MINIO_USE_SSL=false

# Label Studio（初始化与自动标注必填；首次启动 LS 后到 http://localhost:8080 用户设置中创建 API Token 填入）
LABEL_STUDIO_HOST=http://localhost:8080
LABEL_STUDIO_USERNAME=admin@badminton.local
LABEL_STUDIO_PASSWORD=admin_ls_2024
LABEL_STUDIO_API_KEY=你的Label_Studio_API_Key

# ML Backend（可选，自动标注时需要）
ML_BACKEND_HOST=http://localhost:9090
ML_BACKEND_LOG_LEVEL=INFO

# 管理后端（必填，SECRET_KEY 请改为随机字符串）
BACKEND_SECRET_KEY=your_super_secret_key_change_in_production
BACKEND_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
